# ─────────────────────────────────────────────────────────────
#  DevWatch Backend — Environment Configuration Template
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# Local:      mongodb://localhost:27017/devwatch
# Atlas:      mongodb+srv://<user>:<password>@cluster.mongodb.net/devwatch
MONGO_URI=mongodb://localhost:27017/devwatch

# ── Authentication ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_at_least_64_characters
JWT_EXPIRE=7d

# ── AI Integration ────────────────────────────────────────────
OPENAI_API_KEY=sk-replace_with_your_openai_api_key

# ── CORS ──────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Logging ───────────────────────────────────────────────────
# Levels: error | warn | info | http | debug
LOG_LEVEL=info

# ── WebSocket ─────────────────────────────────────────────────
SOCKET_PORT=5000
