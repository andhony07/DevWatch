{
  "name": "devwatch-backend",
  "version": "1.0.0",
  "description": "DevWatch — AI Cloud-Based DevOps Monitoring Dashboard Backend API",
  "type": "module",
  "main": "src/server.js",
  "author": "DevWatch Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "nodemon --ext js,json --watch src src/server.js",
    "start": "node src/server.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js --passWithNoTests --forceExit"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "validator": "^13.12.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.8.0",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3"
  },
  "nodemonConfig": {
    "ignore": [
      "logs/*",
      "tests/*",
      "*.test.js"
    ]
  }
}
